# Dependencies (never copy host node_modules into the build context)
**/node_modules/

# Version control
.git/
.gitignore

# Build output (rebuilt inside Docker)
dist/
apps/client-app/dist/

# TanStack Router generated cache
.tanstack/
apps/client-app/.tanstack/

# Environment files (never bake secrets into images)
**/.env
**/.env.*
**/.env.local
**/.env.*.local

# Editor / IDE config
.vscode/
.idea/
*.code-workspace

# Logs
*.log
logs/

# OS artefacts
.DS_Store
Thumbs.db

# Test artefacts
coverage/
**/*.spec.ts
**/*.test.ts
playwright-report/
test-results/

# CI
.github/
