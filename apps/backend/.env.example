# Environment variables for fisio-app backend

# Database
DATABASE_URL=postgres://user:password@localhost:5432/fisio_app

# Better Auth
BETTER_AUTH_SECRET=your-secret-key-at-least-32-chars-long-change-in-prod
BETTER_AUTH_URL=http://localhost:3000

# Server
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Google Calendar integration (optional — integration disabled until all four are set)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/v1/integrations/google/callback
GCAL_SYNC_ENABLED=false
